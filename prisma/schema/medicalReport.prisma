model MedicalReport {
    id         String   @id @default(uuid(7))
    reportName String
    reportLink String
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    patient   Patient @relation(fields: [patientId], references: [id])
    patientId String

    @@index([patientId], name: "idx_medical_report_patientId")
    @@map("medical_reports")
}
